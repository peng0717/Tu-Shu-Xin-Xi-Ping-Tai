/* 公告详情页样式 */
.container {
  min-height: 100vh;
  background: #fff;
  padding: 20px 16px;
}

.notice-header {
  border-bottom: 1px solid #f0f0f0;
  padding-bottom: 16px;
  margin-bottom: 16px;
}

.notice-title {
  display: block;
  font-size: 20px;
  font-weight: bold;
  color: #333;
  margin-bottom: 12px;
  line-height: 1.4;
}

.notice-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.notice-meta text {
  font-size: 13px;
  color: #999;
}

.notice-body {
  font-size: 15px;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.loading {
  padding: 100px;
  text-align: center;
  color: #999;
}
