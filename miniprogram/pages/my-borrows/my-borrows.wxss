/* 我的借阅记录样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.tabs {
  background: #fff;
  display: flex;
  padding: 0 16px;
  border-bottom: 1px solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 15px;
  color: #666;
  position: relative;
}

.tab.active {
  color: #667eea;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40px;
  height: 3px;
  background: #667eea;
  border-radius: 2px;
}

.borrow-list {
  padding: 12px 16px;
}

.borrow-item {
  background: #fff;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 12px;
  display: flex;
  position: relative;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.borrow-item.overdue {
  border-left: 4px solid #f44336;
}

.book-cover {
  width: 60px;
  height: 80px;
  border-radius: 6px;
  background: #eee;
}

.book-info {
  flex: 1;
  margin-left: 12px;
  display: flex;
  flex-direction: column;
}

.book-title {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
}

.book-author {
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.borrow-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.borrow-info .date {
  font-size: 11px;
  color: #999;
}

.status {
  font-size: 12px;
  margin-top: auto;
}

.status text {
  padding: 2px 8px;
  border-radius: 10px;
}

.status .overdue-tag {
  background: #ffebee;
  color: #f44336;
}

.borrow-item .book-info .status text:not(.overdue-tag) {
  background: #e8f5e9;
  color: #4caf50;
}

.borrow-item .book-info .status text {
  background: #e3f2fd;
  color: #1565c0;
}

.actions {
  position: absolute;
  right: 12px;
  bottom: 12px;
  display: flex;
  gap: 8px;
}

.action-btn {
  padding: 6px 14px;
  border-radius: 16px;
  font-size: 12px;
}

.action-btn.renew {
  background: #e3f2fd;
  color: #1565c0;
}

.action-btn.return {
  background: #e8f5e9;
  color: #4caf50;
}

.empty-state {
  padding: 80px 20px;
  text-align: center;
  color: #999;
}

.empty-state .icon {
  font-size: 64px;
  display: block;
  margin-bottom: 16px;
}

.loading {
  padding: 40px;
  text-align: center;
  color: #999;
}
