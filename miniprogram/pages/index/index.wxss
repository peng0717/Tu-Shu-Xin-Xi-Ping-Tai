/* 首页样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20px;
}

/* 顶部搜索 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40px 16px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.search-box {
  flex: 1;
  background: rgba(255,255,255,0.2);
  border-radius: 25px;
  padding: 10px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-box .placeholder {
  color: rgba(255,255,255,0.8);
  font-size: 14px;
}

.notice-btn {
  width: 40px;
  height: 40px;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

/* 公告轮播 */
.notice-banner {
  background: #fff;
  margin: 12px 16px;
  border-radius: 12px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.notice-icon {
  font-size: 20px;
  margin-right: 12px;
}

.notice-swiper {
  flex: 1;
  height: 24px;
}

.notice-text {
  font-size: 14px;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 区块标题 */
.section {
  margin: 20px 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 13px;
  color: #999;
}

/* 热门图书横向滚动 */
.book-scroll {
  white-space: nowrap;
  padding: 0 16px;
}

.book-item {
  display: inline-block;
  width: 100px;
  margin-right: 12px;
  vertical-align: top;
}

.book-cover {
  width: 100px;
  height: 140px;
  border-radius: 8px;
  background: #eee;
}

.book-item .book-title {
  display: block;
  font-size: 13px;
  color: #333;
  margin-top: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-item .book-author {
  display: block;
  font-size: 11px;
  color: #999;
  margin-top: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 新书上架 */
.new-books {
  padding: 0 16px;
}

.book-card {
  background: #fff;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 12px;
  display: flex;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.book-card .book-cover {
  width: 80px;
  height: 110px;
  border-radius: 6px;
}

.book-info {
  flex: 1;
  margin-left: 12px;
  display: flex;
  flex-direction: column;
}

.book-info .book-title {
  font-size: 15px;
  font-weight: bold;
  color: #333;
  margin-bottom: 6px;
}

.book-info .book-author {
  font-size: 13px;
  color: #666;
  margin-bottom: auto;
}

.book-status {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 12px;
  align-self: flex-start;
  margin-top: 8px;
}

.book-status.available {
  background: #e8f5e9;
  color: #4caf50;
}

.book-status.unavailable {
  background: #ffebee;
  color: #f44336;
}

/* 快速入口 */
.quick-entry {
  display: flex;
  justify-content: space-around;
  padding: 20px 16px;
  background: #fff;
  margin: 20px 16px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.entry-icon {
  width: 50px;
  height: 50px;
  background: linear-gradient(135deg, #667eea20, #764ba220);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.entry-item text {
  font-size: 13px;
  color: #666;
}
